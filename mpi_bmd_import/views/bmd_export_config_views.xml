<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bmd_export_config_form" model="ir.ui.view">
        <field name="name">bmd.export.config.form</field>
        <field name="model">bmd.export.config</field>
        <field name="arch" type="xml">
            <form string="BMD Export Configuration">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="delimiter"/>
                            <field name="encoding"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Header Mappings" name="mappings">
                            <field name="header_mapping_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="bmd_field_name"/>
                                    <field name="odoo_field_name"/>
                                    <field name="export_type"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bmd_export_config_tree" model="ir.ui.view">
        <field name="name">bmd.export.config.tree</field>
        <field name="model">bmd.export.config</field>
        <field name="arch" type="xml">
            <list string="BMD Export Configurations">
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="delimiter"/>
                <field name="encoding"/>
            </list>
        </field>
    </record>

    <record id="action_bmd_export_config" model="ir.actions.act_window">
        <field name="name">BMD Export Configuration</field>
        <field name="res_model">bmd.export.config</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first BMD export configuration
            </p>
            <p>
                Configure delimiter, encoding, and header mappings for BMD export.
            </p>
        </field>
    </record>
</odoo>
