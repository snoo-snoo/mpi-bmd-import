<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bmd_contact_export_wizard_form" model="ir.ui.view">
        <field name="name">bmd.contact.export.wizard.form</field>
        <field name="model">bmd.contact.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Contacts to BMD">
                <group>
                    <group>
                        <field name="config_id"/>
                        <field name="export_format"/>
                        <field name="partner_type"/>
                    </group>
                </group>
                <group invisible="not data">
                    <field name="filename" readonly="1"/>
                    <field name="data" filename="filename" readonly="1"/>
                </group>
                <footer>
                    <button
                        string="Export"
                        name="action_export"
                        type="object"
                        class="btn-primary"
                        invisible="data"
                    />
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bmd_contact_export_wizard" model="ir.actions.act_window">
        <field name="name">Export Contacts to BMD</field>
        <field name="res_model">bmd.contact.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
    </record>
</odoo>
